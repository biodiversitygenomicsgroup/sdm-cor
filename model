                    thr_val <- as.numeric(ens_perf_table$thr_value[ens_perf_table$model == method][1])
                  } else if(!is.null(ensemble_list[[method]]$threshold)) {
                    thr_val <- as.numeric(ensemble_list[[method]]$threshold)
                  } else {
                    next
                  }
                  thr_r <- terra::ifel(con_r >= thr_val, con_r, 0)
                }
                
                bin_r <- terra::ifel(thr_r > 0, 1, 0)
                
                con_path <- file.path(out_pipeline_dir, "07_Ensemble", "03_Projection", f_name, method, "01_con", paste0(sp, ".tif"))
                thr_path <- file.path(out_pipeline_dir, "07_Ensemble", "03_Projection", f_name, method, "02_thr", paste0(sp, ".tif"))
                bin_path <- file.path(out_pipeline_dir, "07_Ensemble", "03_Projection", f_name, method, "03_bin", paste0(sp, ".tif"))
                
                dir.create(dirname(con_path), recursive = TRUE, showWarnings = FALSE)
                dir.create(dirname(thr_path), recursive = TRUE, showWarnings = FALSE)
                dir.create(dirname(bin_path), recursive = TRUE, showWarnings = FALSE)
                
                terra::writeRaster(con_r, con_path, overwrite = TRUE, filetype = "GTiff")
                terra::writeRaster(thr_r, thr_path, overwrite = TRUE, filetype = "GTiff")
                terra::writeRaster(bin_r, bin_path, overwrite = TRUE, filetype = "GTiff")
              }
            }
          }
          
          msg("  ", f_name, ": projections saved")
          rm(future_r)
          gc(verbose = FALSE)
        }
      }
      
      # ========== 14. End of Species Iteration - CLEANUP ==========
      msg("COMPLETE")
      pb$tick()
      
      # Call cleanup function after each species
      cleanup_after_species()
      
    }, error = function(e) {
      msg("ERROR in species processing:", e$message)
      pb$tick()
      cleanup_after_species()
      gc(verbose = FALSE)
    })
    
  }
}

