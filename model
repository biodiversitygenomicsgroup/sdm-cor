cleanup_after_species <- function() {
  # Clean terra internal temp files only (old files only)
  tryCatch({
    terra::tmpFiles(remove = TRUE, old = TRUE)
  }, error = function(e) invisible())
  
  # Single garbage collection pass
  gc(verbose = FALSE)
  
  # Small delay to let OS release file handles
  Sys.sleep(0.1)
}

